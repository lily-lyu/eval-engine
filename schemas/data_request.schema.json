{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/data_request.schema.json",
  "title": "data_request",
  "type": "object",
  "additionalProperties": false,
  "required": ["cluster_id", "issue_type", "priority", "owner_type", "what_to_collect", "template_hint", "verification_eval"],
  "properties": {
    "cluster_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "issue_type": {"type": "string", "minLength": 1, "maxLength": 128},
    "priority": {"type": "integer", "minimum": 1, "maximum": 5},
    "owner_type": {"type": "string", "enum": ["data", "training", "product", "safety", "eval"]},
    "what_to_collect": {"type": "string", "minLength": 1, "maxLength": 8000},
    "template_hint": {"type": "string", "minLength": 1, "maxLength": 8000},
    "verification_eval": {"type": "string", "minLength": 1, "maxLength": 8000}
  }
}
