{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/qa_audit_report.schema.json",
  "title": "qa_audit_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "passed",
    "stage",
    "overall_failure_code",
    "gates",
    "patch_instructions",
    "created_at"
  ],
  "properties": {
    "item_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "stage": { "type": "string" },
    "overall_failure_code": { "type": "string" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "passed", "failure_code", "explanation"],
        "properties": {
          "gate": { "type": "string" },
          "passed": { "type": "boolean" },
          "failure_code": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "patch_instructions": { "type": "string", "minLength": 0, "maxLength": 8000 },
    "created_at": { "type": "string", "format": "date-time" },

    "failure_code": { "type": "string" },
    "explanation": { "type": "string" },

    "version_bundle": { "$ref": "version_bundle.schema.json" },

    "duplicate_metadata": {
      "type": "object",
      "description": "Present when overall_failure_code is DUPLICATE_ITEM; explains what was duplicated and why.",
      "properties": {
        "family_id": { "type": "string" },
        "blueprint_id": { "type": "string" },
        "materializer_type": { "type": "string" },
        "task_type": { "type": "string" },
        "dedup_fingerprint": { "type": "string" },
        "fingerprint_inputs": { "type": "object" },
        "normalized_prompt_skeleton_preview": { "type": "string" },
        "duplicate_match": {
          "type": "object",
          "properties": {
            "same_prompt_skeleton": { "type": "boolean" },
            "same_family": { "type": "boolean" },
            "same_blueprint": { "type": "boolean" },
            "same_materializer": { "type": "boolean" }
          }
        }
      }
    }
  }
}
