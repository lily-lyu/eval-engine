{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/qa_audit_report.schema.json",
  "title": "qa_audit_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "passed",
    "stage",
    "failure_code",
    "explanation",
    "patch_instructions",
    "created_at"
  ],
  "properties": {
    "item_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "stage": { "type": "string" },
    "failure_code": { "type": "string" },
    "explanation": { "type": "string", "minLength": 0, "maxLength": 8000 },
    "patch_instructions": { "type": "string", "minLength": 0, "maxLength": 8000 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
