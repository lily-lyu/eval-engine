{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/qa_audit_report.schema.json",
  "title": "qa_audit_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "passed",
    "stage",
    "overall_failure_code",
    "gates",
    "patch_instructions",
    "created_at"
  ],
  "properties": {
    "item_id": { "type": "string" },
    "passed": { "type": "boolean" },
    "stage": { "type": "string" },
    "overall_failure_code": { "type": "string" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate", "passed", "failure_code", "explanation"],
        "properties": {
          "gate": { "type": "string" },
          "passed": { "type": "boolean" },
          "failure_code": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "patch_instructions": { "type": "string", "minLength": 0, "maxLength": 8000 },
    "created_at": { "type": "string", "format": "date-time" },

    "failure_code": { "type": "string" },
    "explanation": { "type": "string" },

    "version_bundle": { "$ref": "version_bundle.schema.json" }
  }
}
